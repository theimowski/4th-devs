# Optional API key for model-based intent routing in CLI agent.
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional provider override: openai | openrouter.
AI_PROVIDER=

# Optional model override.
OPENAI_MODEL=gpt-5.3-codex

# Local browser UI server.
APPS_HOST=127.0.0.1
APPS_UI_PORT=4321

# Optional override for built UI HTML path.
# Default: dist/ui/index.html
APPS_UI_BUILD_FILE=

# MCP Streamable HTTP endpoint server.
APPS_MCP_PORT=4322

# Auto-open browser at startup (default: false).
APPS_AUTO_OPEN=false

# Markdown files that persist list state.
TODO_FILE=todo.md
SHOPPING_FILE=shopping.md

# debug | info | warn | error
LOG_LEVEL=info
