# Required — at least one key must be set.
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional provider override: openai | openrouter.
AI_PROVIDER=

OPENAI_MODEL=gpt-5.2
SCOUT_MODEL=gpt-5.2
AWARENESS_HISTORY_WINDOW=16
AWARENESS_MAX_TURNS=10
SCOUT_COOLDOWN_SECONDS=180
WEATHER_TTL_MINUTES=180

# pretty | json
LOG_FORMAT=pretty

# debug | info | warn | error
LOG_LEVEL=warn

# Keep demo-seeded workspace/history after `bun run demo` (1 or true).
DEMO_PERSIST=
