# Optional — local fallback works without a key.
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional provider override: openai | openrouter.
AI_PROVIDER=

OPENAI_MODEL=gpt-5.3-codex
RENDER_PORT=4321
RENDER_HOST=127.0.0.1
RENDER_AUTO_OPEN=true

# Optional filename override for `bun run demo` dataset selection.
DEMO_DATASET_FILE=

# debug | info | warn | error
LOG_LEVEL=info
