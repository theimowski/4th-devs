{
  "name": "05_02_ui",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,ui -c cyan,magenta \"bun run dev:server\" \"bun run dev:ui\"",
    "dev:server": "bun --watch server/index.ts",
    "dev:ui": "vite",
    "build": "bun run build:ui && bun run build:server",
    "build:ui": "vite build --outDir dist/client",
    "build:server": "bun build server/index.ts --outdir dist/server --target bun",
    "preview": "NODE_ENV=production bun dist/server/index.js",
    "start": "bun run preview",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "marked": "^15.0.0",
    "openai": "^6.32.0",
    "remend": "^1.3.0",
    "svelte": "^5.54.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
