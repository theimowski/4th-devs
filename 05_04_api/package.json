{
  "name": "05_04_api",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --import tsx src/db/apply-migrations.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "npm run db:seed:main-account",
    "db:seed:main-account": "node --import tsx src/db/seed-main-account.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "@hono/node-server": "^1.19.11",
    "@langfuse/otel": "^5.0.2",
    "@langfuse/tracing": "^5.0.2",
    "@modelcontextprotocol/ext-apps": "^1.3.2",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.9",
    "openai": "^6.33.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
